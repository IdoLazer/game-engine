{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "targetName",
      "description": "Select the target to build/run",
      "type": "pickString",
      "options": ["Game", "Chess"],
      "default": "Game"
    },
    {
      "id": "presetName",
      "description": "Select the CMake preset",
      "type": "pickString",
      "options": ["windows-x64-debug", "windows-x64-release"],
      "default": "windows-x64-debug"
    }
  ],
  "tasks": [
    {
      "label": "Configure",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "${input:presetName}"],
      "group": "build",
      "problemMatcher": [],
      "detail": "Configure all targets for the selected preset"
    },
    {
      "label": "Build",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build/${input:presetName}",
        "--target",
        "${input:targetName}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": "Configure",
      "problemMatcher": ["$gcc"],
      "detail": "Configure + build a target"
    },
    {
      "label": "Clean",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "build/${input:presetName}", "--target", "clean"],
      "group": "build",
      "problemMatcher": [],
      "detail": "Clean built artifacts"
    },
    {
      "label": "Clean Build",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build/${input:presetName}",
        "--target",
        "${input:targetName}"
      ],
      "group": "build",
      "dependsOrder": "sequence",
      "dependsOn": ["Clean", "Configure"],
      "problemMatcher": ["$gcc"],
      "detail": "Clean, reconfigure and build a target"
    },
    {
      "label": "Build + Run",
      "type": "shell",
      "command": ".\\build\\${input:presetName}\\bin\\${input:targetName}\\${input:targetName}.exe",
      "group": "build",
      "dependsOn": "Build",
      "problemMatcher": [],
      "detail": "Build and run a target"
    },
    {
      "label": "Clean Build + Run",
      "type": "shell",
      "command": ".\\build\\${input:presetName}\\bin\\${input:targetName}\\${input:targetName}.exe",
      "group": "build",
      "dependsOn": "Clean Build",
      "problemMatcher": [],
      "detail": "Clean, reconfigure, build and run a target"
    },
    {
      "label": "Run",
      "type": "shell",
      "command": ".\\build\\${input:presetName}\\bin\\${input:targetName}\\${input:targetName}.exe",
      "group": "build",
      "problemMatcher": [],
      "detail": "Run a target without building"
    }
  ]
}
