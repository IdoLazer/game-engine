{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "targetName",
      "description": "Select the target to build/run",
      "type": "pickString",
      "options": ["Snake", "Chess", "Tests"],
      "default": "Snake"
    }
  ],
  "tasks": [
    {
      "label": "Configure (Debug)",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "windows-x64-debug", "--fresh"],
      "group": "build",
      "problemMatcher": [],
      "detail": "Configure debug preset"
    },
    {
      "label": "Clean (Debug)",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "build/windows-x64-debug", "--target", "clean"],
      "group": "build",
      "problemMatcher": [],
      "detail": "Clean debug build artifacts"
    },
    {
      "label": "Build (Debug)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build/windows-x64-debug",
        "--target",
        "${input:targetName}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"],
      "detail": "Build a target with the debug preset"
    },
    {
      "label": "Clean Build (Debug)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build/windows-x64-debug",
        "--target",
        "${input:targetName}"
      ],
      "group": "build",
      "dependsOrder": "sequence",
      "dependsOn": ["Clean (Debug)", "Configure (Debug)"],
      "problemMatcher": ["$gcc"],
      "detail": "Clean, reconfigure and build a target with the debug preset"
    },
    {
      "label": "Build + Run (Debug)",
      "type": "shell",
      "command": ".\\build\\windows-x64-debug\\bin\\${input:targetName}\\${input:targetName}.exe",
      "group": "build",
      "dependsOn": "Build (Debug)",
      "problemMatcher": [],
      "detail": "Build and run a target with the debug preset"
    },
    {
      "label": "Clean Build + Run (Debug)",
      "type": "shell",
      "command": ".\\build\\windows-x64-debug\\bin\\${input:targetName}\\${input:targetName}.exe",
      "group": "build",
      "dependsOn": "Clean Build (Debug)",
      "problemMatcher": [],
      "detail": "Clean, reconfigure, build and run a target with the debug preset"
    },
    {
      "label": "Run (Debug)",
      "type": "shell",
      "command": ".\\build\\windows-x64-debug\\bin\\${input:targetName}\\${input:targetName}.exe",
      "group": "build",
      "problemMatcher": [],
      "detail": "Run a target with the debug preset without building"
    },
    {
      "label": "Build + Test (Debug)",
      "type": "shell",
      "command": "ctest",
      "args": ["--test-dir", "build/windows-x64-debug", "--output-on-failure"],
      "group": "test",
      "dependsOn": "Build Tests (Debug)",
      "problemMatcher": [],
      "detail": "Build and run all tests via CTest (debug)"
    },
    {
      "label": "Build Tests (Debug)",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "build/windows-x64-debug", "--target", "Tests"],
      "group": "build",
      "problemMatcher": ["$gcc"],
      "detail": "Build the Tests target (debug)"
    },
    {
      "label": "Configure (Release)",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "windows-x64-release", "--fresh"],
      "group": "build",
      "problemMatcher": [],
      "detail": "Configure release preset"
    },
    {
      "label": "Build (Release)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build/windows-x64-release",
        "--target",
        "${input:targetName}"
      ],
      "group": "build",
      "problemMatcher": ["$gcc"],
      "detail": "Configure + build a target"
    },
    {
      "label": "Clean (Release)",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "build/windows-x64-release", "--target", "clean"],
      "group": "build",
      "problemMatcher": [],
      "detail": "Clean built artifacts"
    },
    {
      "label": "Clean Build (Release)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build/windows-x64-release",
        "--target",
        "${input:targetName}"
      ],
      "group": "build",
      "dependsOrder": "sequence",
      "dependsOn": ["Clean (Release)", "Configure (Release)"],
      "problemMatcher": ["$gcc"],
      "detail": "Clean, reconfigure and build a target"
    },
    {
      "label": "Build + Run (Release)",
      "type": "shell",
      "command": ".\\build\\windows-x64-release\\bin\\${input:targetName}\\${input:targetName}.exe",
      "group": "build",
      "dependsOn": "Build (Release)",
      "problemMatcher": [],
      "detail": "Build and run a target"
    },
    {
      "label": "Clean Build + Run (Release)",
      "type": "shell",
      "command": ".\\build\\windows-x64-release\\bin\\${input:targetName}\\${input:targetName}.exe",
      "group": "build",
      "dependsOn": "Clean Build (Release)",
      "problemMatcher": [],
      "detail": "Clean, reconfigure, build and run a target"
    },
    {
      "label": "Run (Release)",
      "type": "shell",
      "command": ".\\build\\windows-x64-release\\bin\\${input:targetName}\\${input:targetName}.exe",
      "group": "build",
      "problemMatcher": [],
      "detail": "Run a target without building"
    },
    {
      "label": "Build + Test (Release)",
      "type": "shell",
      "command": "ctest",
      "args": ["--test-dir", "build/windows-x64-release", "--output-on-failure"],
      "group": "test",
      "dependsOn": "Build Tests (Release)",
      "problemMatcher": [],
      "detail": "Build and run all tests via CTest (release)"
    },
    {
      "label": "Build Tests (Release)",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "build/windows-x64-release", "--target", "Tests"],
      "group": "build",
      "problemMatcher": ["$gcc"],
      "detail": "Build the Tests target (release)"
    }
  ]
}
