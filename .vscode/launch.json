{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Chess",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/windows-x64-debug/bin/Chess/Chess.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
