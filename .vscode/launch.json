{
  "version": "0.2.0",
  "inputs": [
    {
      "id": "targetName",
      "description": "Select the target to run",
      "type": "pickString",
      "options": ["Game", "Chess"],
      "default": "Game"
    }
  ],
  "configurations": [
    {
      "name": "Debug (Run)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/windows-x64-debug/bin/${input:targetName}/${input:targetName}.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "Debug (Build + Run)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/windows-x64-debug/bin/${input:targetName}/${input:targetName}.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "Build"
    },
    {
      "name": "Debug (Clean Build + Run)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/windows-x64-debug/bin/${input:targetName}/${input:targetName}.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ],
      "preLaunchTask": "Clean Build"
    }
  ]
}
